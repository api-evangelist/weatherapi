{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/weatherapi/refs/heads/main/json-structure/weatherapi-tide-structure.json",
  "name": "Tide",
  "description": "Tide schema from WeatherAPI.com",
  "type": "object",
  "properties": {
    "tide_time": {
      "type": "string",
      "example": "2026-05-28 04:30"
    },
    "tide_height_mt": {
      "type": "double",
      "example": 1.0
    },
    "tide_type": {
      "type": "string",
      "enum": [
        "High",
        "Low"
      ],
      "example": "High"
    }
  }
}